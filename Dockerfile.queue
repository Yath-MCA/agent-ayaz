FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy task queue system
COPY task_queue_system/ ./task_queue_system/

# Create volume for queue data
VOLUME ["/queue-data"]

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import sys; from task_queue_system import TaskQueueManager; \
    queue = TaskQueueManager('/queue-data'); \
    status = queue.status(); sys.exit(0)"

# Default command - run queue processor
CMD ["python", "-m", "task_queue_system.cli", "run", "--path", "/queue-data"]
