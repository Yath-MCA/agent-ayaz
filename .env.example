PROJECT_ROOT=D:/PERSONAL/LIVE_PROJECTS
# Optional: multiple project roots (Windows separator: ';')
PROJECT_ROOTS=C:/_IMPACT/tomcat/webapps/impact_vite;C:/_IMPACT/tomcat/webapps/impactweb_live;C:/_IMPACT/tomcat/webapps/impact_web

# ── LLM Provider Settings (Auto-fallback in order) ───────────────
# Priority: Ollama > OpenAI > OpenRouter > LM Studio > GitHub Copilot CLI > Mock
# Only configure what you have available - system auto-detects

# 1. Ollama (Local, Free, Preferred)
OLLAMA_MODEL=phi3
OLLAMA_URL=http://localhost:11434
OLLAMA_BIN=D:/Program Files/Ollama/ollama.exe

# 2. OpenAI (Cloud, Paid)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# 3. OpenRouter (Cloud, Free/Paid models available)
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# 4. LM Studio (Local alternative to Ollama)
# LM_STUDIO_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=local-model

# 5. GitHub Copilot CLI (uses `gh copilot suggest`, requires gh CLI authenticated)
#    Install GitHub CLI: https://cli.github.com/
#    Authenticate: gh auth login
#    Each call runs in isolated context (no LLM context rot, like copilot-ralph)
# GITHUB_COPILOT_MODEL=copilot
TELEGRAM_TOKEN=your_bot_token
API_SECRET_KEY=your_super_secret_key
API_SECRET_KEYS=your_super_secret_key,rotated_key_optional
ALLOWED_TELEGRAM_USER_ID=your_telegram_user_id
HOST=0.0.0.0
PORT=9234
CORS_ORIGINS=http://localhost,http://127.0.0.1
COMMAND_TIMEOUT=60
TASK_TIMEOUT=120
MAX_OUTPUT_CHARS=3000
STRICT_COMMAND_MODE=false
ALLOWED_COMMAND_PREFIXES=python,pip,pytest,uv,poetry,npm,pnpm,yarn,node,git,mvn,gradle,dotnet,go,cargo,ruff,black,isort,echo,dir,type,ls
RATE_LIMIT_PER_MINUTE=120
AUTO_APPROVE=true
DEFAULT_EXECUTION_DELAY_SECONDS=0

# ── Git Auto-Commit (inspired by copilot-ralph) ───────────────────
# When true, automatically commits project changes after each successful task execution.
# Each task gets its own commit (like copilot-ralph's per-task commit model).
# Per-request override: set auto_git_commit=true in the request body.
AUTO_GIT_COMMIT=false

# ── Agent System Settings ────────────────────────────────────
# Agent mode: SAFE | CONTROLLED | AUTONOMOUS
#   SAFE       - Requires approval for all tasks
#   CONTROLLED - Auto-approves low-risk (≤3), requires approval for high-risk
#   AUTONOMOUS - Auto-approves all, auto-retries failures
AGENT_MODE=CONTROLLED

# Max risk score for auto-approval in CONTROLLED/AUTONOMOUS modes (1-10)
AUTONOMOUS_RISK_THRESHOLD=3

# Max retry attempts in AUTONOMOUS mode
AUTONOMOUS_MAX_RETRIES=2

# ── RBAC (Role-Based Access Control) ─────────────────────────
# Comma-separated list of api_key:role pairs
# Roles: admin (full access), operator (execute + monitor), viewer (read-only)
# If not set, all keys default to admin
# RBAC_ROLES=api_key_1:admin,api_key_2:operator,api_key_3:viewer

